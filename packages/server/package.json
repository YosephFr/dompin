{
  "name": "@dompin/server",
  "version": "0.1.0",
  "description": "MCP server for DOMPin. Bridges the DOMPin Chrome extension to MCP-compatible coding agents (Claude Code, Cursor, etc.).",
  "license": "MIT",
  "author": "Yoseph Franco <yosephfr@icloud.com>",
  "homepage": "https://github.com/YosephFr/dompin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YosephFr/dompin.git",
    "directory": "packages/server"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "dompin-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "smoke": "node scripts/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dompin/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/ws": "^8.5.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
