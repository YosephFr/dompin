{
  "manifest_version": 3,
  "name": "DOMPin",
  "version": "0.1.0",
  "description": "Pin elements on any web page and save them to a folder ready for your AI coding agent.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "unlimitedStorage", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "action": {
    "default_title": "DOMPin — click to toggle picker, right-click for the panel",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "src/options/options.html",
  "commands": {
    "toggle-picker": {
      "description": "Toggle the DOMPin element picker"
    }
  }
}
