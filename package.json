{
  "name": "dompin",
  "version": "0.1.0",
  "private": true,
  "description": "Pin elements on any web page and write annotated DOM context, screenshots, and component info to a local folder for your AI coding agent.",
  "license": "MIT",
  "author": "Yoseph Franco <yosephfr@icloud.com>",
  "homepage": "https://github.com/YosephFr/dompin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YosephFr/dompin.git"
  },
  "bugs": {
    "url": "https://github.com/YosephFr/dompin/issues"
  },
  "keywords": [
    "chrome-extension",
    "annotation",
    "claude-code",
    "cursor",
    "ai-coding",
    "dom",
    "devtools",
    "file-system-access"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,html,css}\"",
    "validate": "pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2,
    "semi": true,
    "arrowParens": "always"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0"
}
